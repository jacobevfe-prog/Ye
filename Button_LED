const int LED_PIN = 8
const int BUTTON_PIN = 7


void setup() {
  pinMode(LED_PIN, OUTPUT);
  pinMode(BUTTON_PIN, INPUT);
}

void loop() {
  if (digitalRead(BUTTON_PIN) == HIGH) {
    for (int i = 0; i <= 255; i++) {
      analogWrite(LED_PIN, i);
      delay(5);
    }
    delay(255);
    for (int i = 255; i >= 0; i--) {
      analogWrite(LED_PIN, i);
      delay(5);
    }
    //digitalWrite(LED_PIN, HIGH);
  }
  else {
    digitalWrite(LED_PIN, LOW);
  }

}
